{
  "version": 2,
  "rewrites": [
    {
      "source": "/warrior/:id",
      "destination": "/api/warrior/:id"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Content-Type",                 "value": "application/json" }
      ]
    }
  ]
}
